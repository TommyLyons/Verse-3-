rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if the user is the specific admin account
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'I47i5ZR5aAPOMVgQnTYQm2UB3Ym2' || 
        request.auth.token.email == 'verse3records@gmail.com'
      );
    }
    
    // newsletter subscriptions: Readable/Writeable by admin, createable by anyone
    match /newsletterSubscriptions/{subId} {
      allow create: if true;
      allow read, write, list: if isAdmin();
    }

    // User profile and purchase history rules
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());

      match /purchasedProducts/{purchaseId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if isAdmin();
      }
    }

    // Demo submissions rules
    match /demoSubmissions/{submissionId} {
      allow create: if true;
      allow read, write, list: if isAdmin();
    }

    // Store product rules
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Order rules
    match /orders/{orderId} {
        allow create: if true;
        allow read, write, list: if isAdmin();
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    match /demoSubmissions/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    match /{allPaths=**} {
        allow read: if true;
        allow write: if false; 
    }
  }
}