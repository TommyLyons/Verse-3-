
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // God-mode for the Master Admin account
    function isV3Admin() {
      return request.auth != null && (
        request.auth.uid == 'I47i5ZR5aAPOMVgQnTYQm2UB3Ym2' || 
        request.auth.token.email == 'verse3records@gmail.com'
      );
    }
    
    // Global admin override: Admin can do anything
    match /{document=**} {
      allow read, write: if isV3Admin();
    }

    // Public permissions for non-admins
    match /newsletterSubscriptions/{subId} {
      allow create: if true;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /purchasedProducts/{purchaseId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /demoSubmissions/{submissionId} {
      allow create: if true;
    }

    match /products/{productId} {
      allow read: if true;
    }

    match /orders/{orderId} {
      allow create: if true;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    match /demoSubmissions/{allPaths=**} {
      allow read, write: if true;
    }
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false; 
    }
  }
}
