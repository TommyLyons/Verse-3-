
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'verse3records@gmail.com';
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /purchasedProducts/{purchaseId} {
        allow read: if isOwner(userId);
        // In a real app, writes should be handled by a trusted backend server
        // after successful payment verification. For this demo, we allow
        // the user to write to their own record to simulate a purchase.
        allow write: if isOwner(userId);
      }
    }

    match /demoSubmissions/{submissionId} {
      // Allow anyone to submit a demo.
      allow create: if true;
      // Allow admins to read submissions.
      allow read, list: if isAdmin();
      // Disallow public update and delete.
      allow update, delete: if false;
    }

    match /products/{productId} {
      // Allow public read for all products
      allow read, list: if true;
      // Allow admins to create, update, and delete products
      allow write: if isAdmin();
    }

     match /orders/{orderId} {
        // Allow anyone to create an order (guest checkout)
        allow create: if true;
        // Only allow admins to read, update, or delete orders
        allow read, update, delete, list: if isAdmin();
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow public read for demo submission images and audio
    match /demoSubmissions/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Allow uploads
    }
    
    // Allow public read for general app images (e.g. logos, hero images)
    match /{allPaths=**} {
        allow read: if true;
    }
  }
}

    
