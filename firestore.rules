
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'info@verse3records.com';
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /purchasedProducts/{purchaseId} {
        allow read: if isOwner(userId);
        // In a real app, writes should be handled by a trusted backend server
        // after successful payment verification. For this demo, we allow
        // the user to write to their own record to simulate a purchase.
        allow write: if isOwner(userId);
      }
    }

    match /demoSubmissions/{submissionId} {
      // Allow anyone to submit a demo.
      allow create: if true;
      // Allow admins to read submissions.
      allow read, list: if isAdmin();
      // Disallow public update and delete.
      allow update, delete: if false;
    }

    match /products/{productId} {
      // Allow public read for all products
      allow read, list: if true;
      // Allow admins to create, update, and delete products
      allow write: if isAdmin();
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow public read for demo submission images and audio, and product images
    match /demoSubmissions/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Allow uploads
    }

    // Secure digital products (mp3, wav)
    match /digital-products/{fileName} {
      // A user can read a file if a document exists in their purchasedProducts
      // subcollection that references this file.
      allow read: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)/purchasedProducts/$(fileName.split('.')[0]));
    }
    
    // Allow public read for general app images (e.g. logos, hero images)
    match /{allPaths=**} {
        allow read: if true;
    }
  }
}
